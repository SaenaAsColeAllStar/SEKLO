generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// USER & ROLE MANAGEMENT (RBAC)
// -----------------------------------------------------------------------------
enum Role {
  SUPER_ADMIN
  ADMIN_TU
  GURU
  SISWA
  ORANG_TUA
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  role          Role
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relasi berdasarkan Role
  admin         AdminProfile?
  guru          GuruProfile?
  siswa         SiswaProfile?
  orangTua      OrangTuaProfile?
}

// -----------------------------------------------------------------------------
// PROFIL PENGGUNA
// -----------------------------------------------------------------------------
model AdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  namaLengkap String
  noHp      String?
  jabatan   String?  // cth: Kepala TU, Bendahara
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuruProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  nip         String?  @unique
  namaLengkap String
  gelar       String?
  noHp        String?
  mataPelajaran String? // Spesialisasi utama
  isWaliKelas Boolean  @default(false)
  kelasId     String?  @unique // Jika wali kelas
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas       Kelas?   @relation("WaliKelas", fields: [kelasId], references: [id], onDelete: SetNull)
  
  // Relasi Guru
  mengajar    MataPelajaranGuru[]
  tugasElearning Tugas[]
}

model SiswaProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  nisn        String   @unique
  nis         String   @unique
  namaLengkap String
  tempatLahir String?
  tanggalLahir DateTime?
  jenisKelamin String? // L / P
  agama       String?
  alamat      String?
  noHp        String?
  angkatan    Int      // cth: 2023
  status      String   @default("AKTIF") // AKTIF, LULUS, PINDAH, KELUAR
  
  kelasId     String?
  kelas       Kelas?   @relation("AnggotaKelas", fields: [kelasId], references: [id], onDelete: SetNull)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relasi Siswa
  orangTua    HubunganSiswaOrangTua[]
  absensi     Absensi[]
  nilai       Nilai[]
  pengumpulanTugas PengumpulanTugas[]
  pelanggaran PelanggaranSiswa[]
  tagihanSpp  TagihanSpp[]
  anggotaEkskul AnggotaEkstrakurikuler[]
  suaraVoting SuaraVoting[]
}

model OrangTuaProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  namaAyah    String?
  namaIbu     String?
  noHpAyah    String?
  noHpIbu     String?
  pekerjaanAyah String?
  pekerjaanIbu  String?
  alamatLengkap String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relasi Orang Tua
  anak        HubunganSiswaOrangTua[]
}

model HubunganSiswaOrangTua {
  id          String          @id @default(uuid())
  siswaId     String
  orangTuaId  String
  statusHubungan String       // cth: Ayah Kandung, Ibu Kandung, Wali
  
  siswa       SiswaProfile    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  orangTua    OrangTuaProfile @relation(fields: [orangTuaId], references: [id], onDelete: Cascade)

  @@unique([siswaId, orangTuaId])
}

// -----------------------------------------------------------------------------
// AKADEMIK (Kelas, Mata Pelajaran, Jadwal)
// -----------------------------------------------------------------------------
model TingkatKelas {
  id        String   @id @default(uuid())
  nama      String   @unique // cth: X, XI, XII
  kelas     Kelas[]
}

model Jurusan {
  id        String   @id @default(uuid())
  nama      String   @unique // cth: MIPA, IPS, BAHASA
  kelas     Kelas[]
}

model TahunAjaran {
  id        String   @id @default(uuid())
  tahun     String   // cth: 2023/2024
  semester  String   // GANJIL / GENAP
  isActive  Boolean  @default(false)
  
  absensi   Absensi[]
  nilai     Nilai[]
  tagihan   TagihanSpp[]

  @@unique([tahun, semester])
}

model Kelas {
  id             String       @id @default(uuid())
  nama           String       @unique // cth: X MIPA 1
  tingkatKelasId String
  jurusanId      String?
  
  tingkatKelas   TingkatKelas @relation(fields: [tingkatKelasId], references: [id])
  jurusan        Jurusan?     @relation(fields: [jurusanId], references: [id])
  
  siswa          SiswaProfile[] @relation("AnggotaKelas")
  waliKelas      GuruProfile?   @relation("WaliKelas")
  jadwalPelajaran JadwalPelajaran[]
}

model MataPelajaran {
  id          String   @id @default(uuid())
  kode        String   @unique // cth: MAT101
  nama        String   // cth: Matematika Wajib
  kelompok    String?  // cth: Muatan Nasional, Peminatan
  
  guru        MataPelajaranGuru[]
  nilai       Nilai[]
  tugas       Tugas[]
}

model MataPelajaranGuru {
  id              String        @id @default(uuid())
  guruId          String
  mataPelajaranId String
  
  guru            GuruProfile   @relation(fields: [guruId], references: [id], onDelete: Cascade)
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  jadwal          JadwalPelajaran[]

  @@unique([guruId, mataPelajaranId])
}

model JadwalPelajaran {
  id                  String             @id @default(uuid())
  kelasId             String
  mataPelajaranGuruId String
  hari                String             // SENIN, SELASA, dll
  jamMulai            String             // 07:00
  jamSelesai          String             // 08:30
  
  kelas               Kelas              @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  mataPelajaranGuru   MataPelajaranGuru  @relation(fields: [mataPelajaranGuruId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// E-RAPOR & NILAI
// -----------------------------------------------------------------------------
enum TipeNilai {
  TUGAS
  UH        // Ulangan Harian
  UTS       // Ujian Tengah Semester
  UAS       // Ujian Akhir Semester
  KETERAMPILAN
}

model Nilai {
  id              String        @id @default(uuid())
  siswaId         String
  mataPelajaranId String
  tahunAjaranId   String
  tipeNilai       TipeNilai
  skor            Float
  catatanGuru     String?
  
  siswa           SiswaProfile  @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  tahunAjaran     TahunAjaran   @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// -----------------------------------------------------------------------------
// ABSENSI & IOT INTEGRATION
// -----------------------------------------------------------------------------
enum StatusAbsensi {
  HADIR
  SAKIT
  IZIN
  ALPA
  TERLAMBAT
}

model Absensi {
  id            String        @id @default(uuid())
  siswaId       String
  tahunAjaranId String
  tanggal       DateTime      @db.Date
  waktuMasuk    DateTime?     @db.Time
  waktuPulang   DateTime?     @db.Time
  status        StatusAbsensi
  metode        String        @default("MANUAL") // MANUAL, RFID, FINGERPRINT
  keterangan    String?       // Surat dokter, alasan izin, dll
  deviceId      String?       // ID alat IoT jika dari RFID/Fingerprint
  
  siswa         SiswaProfile  @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tahunAjaran   TahunAjaran   @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([siswaId, tanggal])
}

// -----------------------------------------------------------------------------
// E-LEARNING MINI (Manajemen Tugas)
// -----------------------------------------------------------------------------
model Tugas {
  id              String        @id @default(uuid())
  judul           String
  deskripsi       String?       @db.Text
  fileUrl         String?       // Link ke lampiran materi/tugas
  tenggatWaktu    DateTime
  guruId          String
  mataPelajaranId String
  
  guru            GuruProfile   @relation(fields: [guruId], references: [id], onDelete: Cascade)
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id], onDelete: Cascade)
  pengumpulan     PengumpulanTugas[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PengumpulanTugas {
  id          String        @id @default(uuid())
  tugasId     String
  siswaId     String
  fileUrl     String?       // Link ke file jawaban siswa
  teksJawaban String?       @db.Text
  waktuKumpul DateTime      @default(now())
  nilai       Float?        // Nilai spesifik untuk tugas ini
  komentarGuru String?      @db.Text
  
  tugas       Tugas         @relation(fields: [tugasId], references: [id], onDelete: Cascade)
  siswa       SiswaProfile  @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@unique([tugasId, siswaId])
}

// -----------------------------------------------------------------------------
// KEDISIPLINAN (Buku Saku / BK)
// -----------------------------------------------------------------------------
model Pelanggaran {
  id          String        @id @default(uuid())
  nama        String        // cth: Terlambat, Merokok, Bolos
  poin        Int           // Bobot pelanggaran
  kategori    String        // RINGAN, SEDANG, BERAT
  
  kasus       PelanggaranSiswa[]
}

model PelanggaranSiswa {
  id            String        @id @default(uuid())
  siswaId       String
  pelanggaranId String
  tanggal       DateTime      @default(now())
  keterangan    String?       @db.Text
  ditindakOleh  String        // Nama Guru BK atau yang menindak
  
  siswa         SiswaProfile  @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  pelanggaran   Pelanggaran   @relation(fields: [pelanggaranId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// KEUANGAN (E-SPP & Pembayaran Digital)
// -----------------------------------------------------------------------------
enum StatusPembayaran {
  UNPAID
  PENDING
  PAID
  FAILED
}

model TagihanSpp {
  id            String        @id @default(uuid())
  siswaId       String
  tahunAjaranId String
  bulan         String        // cth: JANUARI, FEBRUARI
  nominal       Float
  status        StatusPembayaran @default(UNPAID)
  jatuhTempo    DateTime
  
  // Midtrans / Payment Gateway Tracking
  orderId       String?       @unique // ID transaksi ke payment gateway
  paymentUrl    String?       // Link pembayaran
  paymentMethod String?       // VA BCA, Gopay, dll
  paidAt        DateTime?
  
  siswa         SiswaProfile  @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tahunAjaran   TahunAjaran   @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  transaksi     TransaksiKeuangan[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Untuk mencatat pemasukan lain / detail transaksi
model TransaksiKeuangan {
  id            String        @id @default(uuid())
  tagihanSppId  String?
  keterangan    String        // cth: Pembayaran SPP Januari 2024, Donasi, Uang Pangkal
  nominal       Float
  jenis         String        // PEMASUKAN / PENGELUARAN
  tanggal       DateTime      @default(now())
  metode        String        // TUNAI, TRANSFER_BANK, PAYMENT_GATEWAY
  
  tagihanSpp    TagihanSpp?   @relation(fields: [tagihanSppId], references: [id], onDelete: SetNull)
}

// -----------------------------------------------------------------------------
// EKSTRAKURIKULER & ORGANISASI
// -----------------------------------------------------------------------------
model Ekstrakurikuler {
  id          String        @id @default(uuid())
  nama        String        @unique // cth: Pramuka, Basket, PMR
  deskripsi   String?       @db.Text
  pembinaId   String?       // ID Guru
  
  anggota     AnggotaEkstrakurikuler[]
}

model AnggotaEkstrakurikuler {
  id                String          @id @default(uuid())
  siswaId           String
  ekstrakurikulerId String
  jabatan           String          @default("ANGGOTA") // KETUA, SEKRETARIS, ANGGOTA
  tahunBergabung    Int
  
  siswa             SiswaProfile    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  ekstrakurikuler   Ekstrakurikuler @relation(fields: [ekstrakurikulerId], references: [id], onDelete: Cascade)

  @@unique([siswaId, ekstrakurikulerId])
}

// -----------------------------------------------------------------------------
// E-VOTING (Pemilihan Ketua OSIS)
// -----------------------------------------------------------------------------
model Pemilihan {
  id          String        @id @default(uuid())
  judul       String        // cth: Pemilihan Ketua OSIS 2024
  deskripsi   String?       @db.Text
  waktuMulai  DateTime
  waktuSelesai DateTime
  isActive    Boolean       @default(false)
  
  kandidat    Kandidat[]
}

model Kandidat {
  id          String        @id @default(uuid())
  pemilihanId String
  nama        String
  visiMisi    String        @db.Text
  fotoUrl     String?
  noUrut      Int
  
  pemilihan   Pemilihan     @relation(fields: [pemilihanId], references: [id], onDelete: Cascade)
  suara       SuaraVoting[]
}

model SuaraVoting {
  id          String        @id @default(uuid())
  kandidatId  String
  siswaId     String
  waktuVote   DateTime      @default(now())
  
  kandidat    Kandidat      @relation(fields: [kandidatId], references: [id], onDelete: Cascade)
  siswa       SiswaProfile  @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  // Satu siswa hanya bisa vote sekali per pemilihan (logic ini dihandle di app, tapi db ngebatesin via kandidat sementara)
  @@unique([kandidatId, siswaId])
}

// -----------------------------------------------------------------------------
// PPDB (Penerimaan Peserta Didik Baru)
// -----------------------------------------------------------------------------
enum StatusPPDB {
  MENUNGGU_VERIFIKASI
  LOLOS_BERKAS
  DITERIMA
  DITOLAK
  CABUT_BERKAS
}

model PendaftaranPPDB {
  id              String        @id @default(uuid())
  noPendaftaran   String        @unique
  namaLengkap     String
  nisn            String        @unique
  sekolahAsal     String
  nilaiRataRata   Float?
  berkasUrl       String?       // Link ke zip dokumen
  status          StatusPPDB    @default(MENUNGGU_VERIFIKASI)
  catatanAdmin    String?       @db.Text
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// -----------------------------------------------------------------------------
// INVENTARIS & SARPRAS
// -----------------------------------------------------------------------------
model BarangInventaris {
  id          String        @id @default(uuid())
  kodeBarang  String        @unique
  nama        String
  kategori    String        // cth: Elektronik, Olahraga, Buku
  kondisi     String        // BAIK, RUSAK_RINGAN, RUSAK_BERAT
  jumlahTotal Int
  jumlahTersedia Int
  
  peminjaman  PeminjamanBarang[]
}

model PeminjamanBarang {
  id              String        @id @default(uuid())
  barangId        String
  peminjam        String        // Nama peminjam (Siswa/Guru)
  jumlah          Int
  tanggalPinjam   DateTime      @default(now())
  tanggalKembali  DateTime?
  status          String        @default("DIPINJAM") // DIPINJAM, DIKEMBALIKAN, HILANG
  
  barang          BarangInventaris @relation(fields: [barangId], references: [id], onDelete: Cascade)
}
